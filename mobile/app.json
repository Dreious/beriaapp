{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Chat icin kameraya erisim gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Chatte fotoğraf gonderebilmek icin galeriye erisim gerekiyor.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.beross.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Chat icin kameraya erisim gerekiyor.",
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chatte fotoğraf gonderebilmek icin galeriye erisim gerekiyor."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "5753d61e-f29f-4661-8d0e-425db7799293"
      }
    }
  }
}
